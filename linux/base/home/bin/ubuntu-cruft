#!/usr/bin/env bash
# Conservative Ubuntu/Debian cruft review and cleanup.
#
# Default is report-only. Destructive actions always simulate (APT) and ask
# (default N). Never disables APT sources, never removes the running kernel,
# never deletes user data under $HOME.
#
# Usage:
#   ubuntu-cruft                 # same as: report
#   ubuntu-cruft report          # findings only
#   ubuntu-cruft all             # comprehensive interactive pass
#   ubuntu-cruft <section>       # one area (see --help)
#   ubuntu-cruft keep list|add|remove
#
# Keep list: ~/.config/ubuntu-cruft/keep  (one package/snap name per line)

set -u
set -o pipefail

readonly SCRIPT_NAME=${0##*/}
readonly CONFIG_DIR=${XDG_CONFIG_HOME:-$HOME/.config}/ubuntu-cruft
readonly KEEP_FILE=$CONFIG_DIR/keep
readonly KERNEL_KEEP_FALLBACKS=1   # advise retaining this many non-running kernels
readonly JOURNAL_VACUUM_SIZE=200M

MODE=apply          # report | apply
JSON_SUMMARY=0
INCLUDE_DEBORPHAN=0
INCLUDE_SLOW=0      # disk du / large manual pkgs in report+all when set

bold=$'\033[1m'
red=$'\033[31m'
yellow=$'\033[33m'
green=$'\033[32m'
dim=$'\033[2m'
reset=$'\033[0m'

# Summary counters (text + optional JSON).
declare -i FINDINGS=0
declare -i ACTIONS_DONE=0
declare -i ACTIONS_SKIPPED=0
declare -a FINDING_LABELS=()

usage() {
    cat <<EOF
Usage: $SCRIPT_NAME [options] [<command>]

Commands (default: report):
  report              Print findings only; make no changes (default)
  all                 Comprehensive interactive pass over every section
  health              Package database health + held packages
  residual            Residual dpkg configuration packages
  autoremove          APT autoremove --purge candidates
  local               Packages installed but unavailable from repos
  kernels             Installed kernel packages (review / policy)
  sources             APT source files + stale suite names
  manual              Largest manually installed packages
  cache               APT package cache (autoclean / clean)
  journal             systemd journal disk usage / vacuum
  snaps               Disabled Snap revisions
  pyenv               pyenv versions (review only)
  disk                Largest top-level directories on /
  deborphan           Orphaned libraries via deborphan (optional tool)
  keep list           Show keep-list entries
  keep add NAME...    Add names to keep list
  keep remove NAME... Remove names from keep list

Options:
  -h, --help          Show this help
  --apply             Allow interactive fixes (implied by section commands
                      other than report; report stays read-only)
  --report            Force report-only even with section commands
  --json-summary      Print a JSON summary object at the end
  --deborphan         Include deborphan in report/all
  --slow              Include disk + large-manual sections in report/all

Keep list: $KEEP_FILE
EOF
}

section() { printf '\n%s== %s ==%s\n' "$bold" "$*" "$reset"; }
info()    { printf '%s%s%s\n' "$green" "$*" "$reset"; }
warn()    { printf '%s%s%s\n' "$yellow" "$*" "$reset"; }
error()   { printf '%s%s%s\n' "$red" "$*" "$reset" >&2; }
note()    { printf '%s%s%s\n' "$dim" "$*" "$reset"; }

ask() {
    local reply
    [[ $MODE == report ]] && return 1
    read -r -p "$1 [y/N] " reply
    [[ $reply =~ ^[Yy]([Ee][Ss])?$ ]]
}

shell_join() {
    local out=() arg
    for arg in "$@"; do
        printf -v arg '%q' "$arg"
        out+=("$arg")
    done
    printf '%s' "${out[*]}"
}

record_finding() {
    FINDINGS+=1
    FINDING_LABELS+=("$*")
}

ensure_not_root() {
    if [[ ${EUID:-$(id -u)} -eq 0 ]]; then
        error "Run as your normal user; sudo is invoked when needed."
        exit 1
    fi
}

ensure_apt() {
    if ! command -v apt-get >/dev/null || ! command -v dpkg-query >/dev/null; then
        error "This script requires an APT/dpkg-based system."
        exit 1
    fi
}

suite_from_os() {
    # shellcheck source=/dev/null
    . /etc/os-release
    printf '%s' "${VERSION_CODENAME:-}"
}

running_kernel=$(uname -r)
current_suite=$(suite_from_os)

# --- keep list -------------------------------------------------------------

ensure_keep_file() {
    mkdir -p "$CONFIG_DIR"
    [[ -f $KEEP_FILE ]] || : >"$KEEP_FILE"
}

is_kept() {
    local name=$1
    [[ -f $KEEP_FILE ]] || return 1
    grep -Fxq -- "$name" "$KEEP_FILE"
}

filter_kept() {
    # stdin: names, one per line → stdout: names not on keep list
    local name
    while IFS= read -r name; do
        [[ -z $name ]] && continue
        if is_kept "$name"; then
            note "keep: skipping $name"
            continue
        fi
        printf '%s\n' "$name"
    done
}

cmd_keep() {
    local sub=${1:-list}
    shift || true
    ensure_keep_file
    case "$sub" in
        list)
            if [[ ! -s $KEEP_FILE ]]; then
                info "Keep list is empty ($KEEP_FILE)."
                return 0
            fi
            printf 'Keep list (%s):\n' "$KEEP_FILE"
            cat "$KEEP_FILE"
            ;;
        add)
            (( $# )) || { error "keep add requires at least one name"; return 1; }
            local n
            for n in "$@"; do
                if is_kept "$n"; then
                    note "already kept: $n"
                else
                    printf '%s\n' "$n" >>"$KEEP_FILE"
                    info "added to keep list: $n"
                fi
            done
            ;;
        remove)
            (( $# )) || { error "keep remove requires at least one name"; return 1; }
            local n tmp
            for n in "$@"; do
                tmp=$(mktemp)
                grep -Fxv -- "$n" "$KEEP_FILE" >"$tmp" || true
                mv "$tmp" "$KEEP_FILE"
                info "removed from keep list: $n"
            done
            ;;
        *)
            error "unknown keep subcommand: $sub (use list|add|remove)"
            return 1
            ;;
    esac
}

# --- kernel policy ---------------------------------------------------------

is_protected_kernel_package() {
    local pkg=$1
    case "$pkg" in
        linux-image-"$running_kernel"|\
        linux-image-unsigned-"$running_kernel"|\
        linux-modules-"$running_kernel"|\
        linux-modules-extra-"$running_kernel"|\
        linux-headers-"$running_kernel"|\
        linux-headers-generic|\
        linux-image-generic|\
        linux-generic)
            return 0
            ;;
    esac
    return 1
}

list_installed_kernel_images() {
    dpkg-query -W -f='${db:Status-Abbrev}\t${binary:Package}\n' 'linux-image-[0-9]*' 2>/dev/null |
        awk '$1 ~ /^ii/ && $2 !~ /^(linux-image-generic|linux-image-unsigned-generic)$/ {print $2}' |
        sort -V
}

# --- apt helpers -----------------------------------------------------------

apt_shows_removals() {
    grep -Eq '^(Remv|Purg) |^[0-9]+ upgraded, [0-9]+ newly installed, [1-9][0-9]* to remove' <<<"$1"
}

# Run apt-get --simulate; in apply mode, offer to execute.
# Returns 0 if simulation ok (whether or not anything was removed).
apt_simulate_and_offer() {
    local description=$1
    shift
    local -a cmd=("$@")
    local output rc

    section "$description"
    # Place "--" only before package names in cmd, never before the subcommand.
    output=$(sudo apt-get --simulate "${cmd[@]}" 2>&1)
    rc=$?
    printf '%s\n' "$output"
    if (( rc != 0 )); then
        warn "APT simulation failed; nothing will be changed."
        return 1
    fi

    if ! apt_shows_removals "$output"; then
        info "Nothing to remove."
        return 0
    fi

    record_finding "apt: ${cmd[*]}"

    if [[ $MODE == report ]]; then
        note "Report mode: not offering removal. Re-run with: $SCRIPT_NAME ${cmd[0]}"
        return 0
    fi

    if ask "Run the real command: sudo apt-get $(shell_join "${cmd[@]}")?"; then
        sudo apt-get "${cmd[@]}"
        ACTIONS_DONE+=1
    else
        info "Skipped."
        ACTIONS_SKIPPED+=1
    fi
}

offer_purge_each() {
    local label=$1
    shift
    local -a pkgs=("$@")
    local pkg

    ((${#pkgs[@]})) || return 0

    for pkg in "${pkgs[@]}"; do
        if is_protected_kernel_package "$pkg"; then
            warn "$pkg is protected (running kernel / metapackage); skipping."
            continue
        fi
        if is_kept "$pkg"; then
            note "keep: skipping $pkg"
            continue
        fi

        record_finding "$label: $pkg"

        if [[ $MODE == report ]]; then
            continue
        fi

        if ask "Simulate purging $label '$pkg'?"; then
            apt_simulate_and_offer "Review removal of $pkg" purge -- "$pkg"
        else
            ACTIONS_SKIPPED+=1
        fi
    done
}

# --- sections --------------------------------------------------------------

cmd_summary() {
    section "System summary"
    printf 'Host:             %s\n' "$(hostname)"
    # shellcheck source=/dev/null
    printf 'Ubuntu/Debian:    %s\n' "$(. /etc/os-release; printf '%s (%s)' "$PRETTY_NAME" "${VERSION_CODENAME:-unknown}")"
    printf 'Running kernel:   %s\n' "$running_kernel"
    printf 'Root filesystem:  %s\n' "$(df -hP / | awk 'NR==2 {print $3 " used of " $2 " (" $5 ")"}')"
    printf 'Mode:             %s\n' "$MODE"
    printf 'Keep list:        %s\n' "$KEEP_FILE"
}

cmd_health() {
    section "Package database health"
    if sudo dpkg --audit; then
        info "No incomplete or broken package states were reported."
    else
        warn "dpkg reported a problem. Resolve that before optional cleanup."
        record_finding "dpkg audit issues"
    fi

    if ! sudo apt-get check; then
        error "APT dependency check failed. Repair this before cleanup."
        record_finding "apt-get check failed"
        if [[ $MODE == apply ]]; then
            exit 1
        fi
        return 1
    fi
    info "APT dependency check passed."

    section "Held packages"
    local holds
    holds=$(apt-mark showhold)
    if [[ -n $holds ]]; then
        printf '%s\n' "$holds"
        warn "Held packages are not cruft; verify each hold is intentional."
        record_finding "held packages present"
    else
        info "No packages are held."
    fi
}

cmd_residual() {
    section "Residual configuration files"
    local -a rc_packages=()
    mapfile -t rc_packages < <(
        dpkg-query -W -f='${db:Status-Abbrev}\t${binary:Package}\n' 2>/dev/null |
            awk '$1 ~ /^rc/ {print $2}' |
            filter_kept
    )

    if ((${#rc_packages[@]} == 0)); then
        info "No residual-config packages found."
        return 0
    fi

    printf '%s\n' "${rc_packages[@]}"
    warn "Already removed; only dpkg-managed configuration remains (${#rc_packages[@]})."
    record_finding "residual configs: ${#rc_packages[@]}"

    if [[ $MODE == report ]]; then
        note "Report mode. Apply with: $SCRIPT_NAME residual"
        return 0
    fi

    if ask "Purge all listed residual configurations?"; then
        sudo dpkg --purge -- "${rc_packages[@]}"
        ACTIONS_DONE+=1
    else
        info "Skipped."
        ACTIONS_SKIPPED+=1
    fi
}

cmd_autoremove() {
    apt_simulate_and_offer "Automatically installed dependencies no longer required" \
        autoremove --purge
}

cmd_local() {
    section "Installed packages unavailable from enabled repositories"
    local -a local_packages=()
    mapfile -t local_packages < <(
        apt list --installed 2>/dev/null |
            awk -F/ '/\[installed,local\]/{print $1}' |
            sort -u |
            filter_kept
    )

    if ((${#local_packages[@]} == 0)); then
        info "No installed-local packages found."
        return 0
    fi

    warn "May be old-release/PPA leftovers, or intentional local .deb packages."
    printf '%-42s %12s  %s\n' "PACKAGE" "SIZE" "VERSION"
    local pkg
    for pkg in "${local_packages[@]}"; do
        dpkg-query -W -f='${binary:Package}\t${Installed-Size}\t${Version}\n' "$pkg" 2>/dev/null |
            awk -F'\t' '{printf "%-42s %8.1f MiB  %s\n", $1, $2/1024, $3}'
    done
    echo
    offer_purge_each "local package" "${local_packages[@]}"
}

cmd_kernels() {
    section "Installed kernels"
    printf 'Running: %s\n' "$running_kernel"
    printf 'Policy:  never remove the running kernel; retain ≥ %s known-good fallback(s).\n' \
        "$KERNEL_KEEP_FALLBACKS"
    printf 'Prefer:  apt autoremove for old kernels over manual linux-image removal.\n\n'

    dpkg-query -W -f='${db:Status-Abbrev}\t${binary:Package}\t${Version}\n' \
        'linux-image-[0-9]*' 'linux-modules-[0-9]*' \
        'linux-modules-extra-[0-9]*' 'linux-headers-[0-9]*' 2>/dev/null |
        awk '$1 ~ /^ii/ {print $2 "\t" $3}' | sort -V || true

    local -a images=()
    mapfile -t images < <(list_installed_kernel_images)
    local -i image_count=${#images[@]}

    if (( image_count > KERNEL_KEEP_FALLBACKS + 1 )); then
        warn "Found $image_count linux-image packages; extras beyond running + $KERNEL_KEEP_FALLBACKS fallback(s) may be removable via autoremove."
        record_finding "kernel images: $image_count (review)"
    else
        info "Kernel image count ($image_count) is within the keep policy window."
    fi
    note "This section never removes packages; use: $SCRIPT_NAME autoremove"
}

cmd_deborphan() {
    section "deborphan review"
    if ! command -v deborphan >/dev/null; then
        warn "deborphan is not installed (optional; Ubuntu Universe)."
        if [[ $MODE == apply ]] && ask "Install deborphan now?"; then
            if sudo apt-get install -- deborphan; then
                ACTIONS_DONE+=1
            else
                warn "Install failed."
                ACTIONS_SKIPPED+=1
                return 1
            fi
        else
            record_finding "deborphan not installed"
            return 0
        fi
    fi

    local -a orphans=()
    mapfile -t orphans < <(deborphan 2>/dev/null | sort -u | filter_kept)
    if ((${#orphans[@]} == 0)); then
        info "deborphan found no orphaned libraries."
        return 0
    fi

    printf '%s\n' "${orphans[@]}"
    warn "Means 'nothing depends on this library,' not 'you do not use it.'"
    offer_purge_each "deborphan candidate" "${orphans[@]}"
}

cmd_sources() {
    section "APT source files and release names"
    local known_suites=(
        trusty xenial bionic focal jammy noble oracular plucky questing resolute
        stretch buster bullseye bookworm trixie forky
        kinetic lunar mantic
    )
    local stale=0
    shopt -s nullglob
    local source_files=(/etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources)
    local file suite
    for file in "${source_files[@]}"; do
        [[ -f $file ]] || continue
        printf '\n%s\n' "$file"
        grep -Ev '^[[:space:]]*(#|$)' "$file" 2>/dev/null || true
        for suite in "${known_suites[@]}"; do
            if [[ -n $current_suite && $suite != "$current_suite" ]] &&
                grep -Eq "(^|[[:space:]/])${suite}([[:space:]/-]|$)" "$file"; then
                warn "Mentions '$suite'; current suite is '$current_suite'. Review manually."
                stale=1
            fi
        done
    done
    (( stale )) && record_finding "stale suite names in APT sources"
    warn "Never auto-disables repositories; review third-party entries by hand."
}

cmd_manual() {
    section "Largest manually installed packages"
    printf '%-42s %12s  %s\n' "PACKAGE" "SIZE" "DESCRIPTION"
    while IFS= read -r pkg; do
        dpkg-query -W -f='${binary:Package}\t${Installed-Size}\t${binary:Summary}\n' "$pkg" 2>/dev/null
    done < <(apt-mark showmanual) |
        sort -t$'\t' -k2,2nr |
        head -40 |
        awk -F'\t' '{printf "%-42s %8.1f MiB  %s\n", $1, $2/1024, $3}'
    warn "Manual packages are not removal candidates; human review only."
}

cmd_cache() {
    section "APT package cache"
    local cache_kib
    cache_kib=$(du -sk /var/cache/apt/archives 2>/dev/null | awk '{print $1+0}')
    printf 'Current cache size: %.1f MiB\n' "$(awk -v k="$cache_kib" 'BEGIN{print k/1024}')"

    if (( cache_kib > 102400 )); then
        record_finding "APT cache > 100 MiB"
    fi

    if [[ $MODE == report ]]; then
        note "Report mode. Apply with: $SCRIPT_NAME cache"
        return 0
    fi

    if ask "Run apt-get autoclean (obsolete cached packages only)?"; then
        sudo apt-get autoclean
        ACTIONS_DONE+=1
    else
        info "Skipped autoclean."
        ACTIONS_SKIPPED+=1
    fi
    if ask "Run apt-get clean (all cached .deb files)?"; then
        sudo apt-get clean
        ACTIONS_DONE+=1
    else
        info "Skipped clean."
        ACTIONS_SKIPPED+=1
    fi
}

cmd_journal() {
    section "systemd journal"
    sudo journalctl --disk-usage || true

    if [[ $MODE == report ]]; then
        note "Report mode. Apply with: $SCRIPT_NAME journal"
        return 0
    fi

    if ask "Vacuum archived journal data down to $JOURNAL_VACUUM_SIZE?"; then
        sudo journalctl --vacuum-size="$JOURNAL_VACUUM_SIZE"
        ACTIONS_DONE+=1
    else
        info "Skipped journal vacuum."
        ACTIONS_SKIPPED+=1
    fi
}

cmd_snaps() {
    section "Disabled Snap revisions"
    if ! command -v snap >/dev/null; then
        info "Snap is not installed."
        return 0
    fi

    local -a disabled_snaps=()
    mapfile -t disabled_snaps < <(
        snap list --all 2>/dev/null |
            awk 'NR>1 && $NF=="disabled" {print $1 " " $3}'
    )

    if ((${#disabled_snaps[@]} == 0)); then
        info "No disabled Snap revisions found."
        return 0
    fi

    local item name revision
    local -a to_consider=()
    for item in "${disabled_snaps[@]}"; do
        read -r name revision <<<"$item"
        if is_kept "$name" || is_kept "$name/$revision"; then
            note "keep: skipping $name revision $revision"
            continue
        fi
        to_consider+=("$item")
    done

    if ((${#to_consider[@]} == 0)); then
        info "All disabled revisions are on the keep list."
        return 0
    fi

    printf '%s\n' "${to_consider[@]}"
    warn "Old disabled revisions; Snap retains them for rollback."
    record_finding "disabled snap revisions: ${#to_consider[@]}"

    if [[ $MODE == report ]]; then
        note "Report mode. Apply with: $SCRIPT_NAME snaps"
        return 0
    fi

    for item in "${to_consider[@]}"; do
        read -r name revision <<<"$item"
        if ask "Remove disabled snap $name revision $revision?"; then
            sudo snap remove "$name" --revision="$revision"
            ACTIONS_DONE+=1
        else
            info "Skipped $name revision $revision."
            ACTIONS_SKIPPED+=1
        fi
    done
}

cmd_pyenv() {
    section "pyenv versions"
    if command -v pyenv >/dev/null; then
        pyenv versions
        warn "User-managed. Remove with: pyenv uninstall VERSION"
    else
        info "pyenv is not available in this shell."
    fi
}

cmd_disk() {
    section "Largest top-level directories on the root filesystem"
    warn "Read-only; can take a while on large disks."
    sudo du -x -h --max-depth=1 / 2>/dev/null | sort -h
    warn "Diagnostic only; not deletion targets."
}

print_summary() {
    section "Summary"
    printf 'Findings:        %s\n' "$FINDINGS"
    printf 'Actions done:    %s\n' "$ACTIONS_DONE"
    printf 'Actions skipped: %s\n' "$ACTIONS_SKIPPED"
    if (( FINDINGS )); then
        printf '\nFinding labels:\n'
        local label
        for label in "${FINDING_LABELS[@]}"; do
            printf '  - %s\n' "$label"
        done
    fi
    if [[ $MODE == report ]]; then
        note "Report-only run. Apply fixes with section commands or: $SCRIPT_NAME all"
    fi

    if (( JSON_SUMMARY )); then
        local labels_json=""
        local i first=1
        labels_json='['
        for (( i = 0; i < ${#FINDING_LABELS[@]}; i++ )); do
            local escaped=${FINDING_LABELS[i]//\\/\\\\}
            escaped=${escaped//\"/\\\"}
            if (( first )); then first=0; else labels_json+=','; fi
            labels_json+="\"$escaped\""
        done
        labels_json+=']'
        printf '\n{"findings":%s,"actions_done":%s,"actions_skipped":%s,"mode":"%s","labels":%s}\n' \
            "$FINDINGS" "$ACTIONS_DONE" "$ACTIONS_SKIPPED" "$MODE" "$labels_json"
    fi
}

run_report() {
    MODE=report
    cmd_summary
    cmd_health
    cmd_residual
    cmd_autoremove
    cmd_local
    cmd_kernels
    cmd_sources
    cmd_cache
    cmd_journal
    cmd_snaps
    cmd_pyenv
    if (( INCLUDE_DEBORPHAN )); then
        cmd_deborphan
    else
        note "Skipping deborphan (pass --deborphan or: $SCRIPT_NAME deborphan)."
    fi
    if (( INCLUDE_SLOW )); then
        cmd_manual
        cmd_disk
    else
        note "Skipping slow sections (pass --slow or: $SCRIPT_NAME manual|disk)."
    fi
    print_summary
}

run_all() {
    MODE=apply
    cmd_summary
    cmd_health
    cmd_residual
    cmd_autoremove
    cmd_local
    cmd_kernels
    if (( INCLUDE_DEBORPHAN )); then
        cmd_deborphan
    else
        note "Skipping deborphan (pass --deborphan to include in all)."
    fi
    cmd_sources
    if (( INCLUDE_SLOW )); then
        cmd_manual
    fi
    cmd_cache
    cmd_journal
    cmd_snaps
    cmd_pyenv
    if (( INCLUDE_SLOW )); then
        cmd_disk
    else
        note "Skipping disk du (pass --slow to include in all)."
    fi
    print_summary
    info "Re-run after removals; new autoremove candidates can appear."
}

# --- argv ------------------------------------------------------------------

COMMAND=""
POSITIONAL=()

while (( $# )); do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --apply)
            MODE=apply
            shift
            ;;
        --report)
            MODE=report
            shift
            ;;
        --json-summary)
            JSON_SUMMARY=1
            shift
            ;;
        --deborphan)
            INCLUDE_DEBORPHAN=1
            shift
            ;;
        --slow)
            INCLUDE_SLOW=1
            shift
            ;;
        -*)
            error "Unknown option: $1"
            usage >&2
            exit 2
            ;;
        *)
            POSITIONAL+=("$1")
            shift
            ;;
    esac
done

set -- "${POSITIONAL[@]+"${POSITIONAL[@]}"}"
COMMAND=${1:-report}
shift || true

# keep list management does not need apt/root checks beyond write access
if [[ $COMMAND != keep ]]; then
    ensure_not_root
    ensure_apt
fi

case "$COMMAND" in
    report)
        run_report
        ;;
    all|full)
        run_all
        ;;
    health)
        MODE=apply
        cmd_summary
        cmd_health
        print_summary
        ;;
    residual)
        [[ $MODE == report ]] || MODE=apply
        cmd_residual
        print_summary
        ;;
    autoremove)
        [[ $MODE == report ]] || MODE=apply
        cmd_autoremove
        print_summary
        ;;
    local)
        [[ $MODE == report ]] || MODE=apply
        cmd_local
        print_summary
        ;;
    kernels)
        MODE=report
        cmd_kernels
        print_summary
        ;;
    sources)
        MODE=report
        cmd_sources
        print_summary
        ;;
    manual)
        MODE=report
        cmd_manual
        print_summary
        ;;
    cache)
        [[ $MODE == report ]] || MODE=apply
        cmd_cache
        print_summary
        ;;
    journal)
        [[ $MODE == report ]] || MODE=apply
        cmd_journal
        print_summary
        ;;
    snaps)
        [[ $MODE == report ]] || MODE=apply
        cmd_snaps
        print_summary
        ;;
    pyenv)
        MODE=report
        cmd_pyenv
        print_summary
        ;;
    disk)
        MODE=report
        cmd_disk
        print_summary
        ;;
    deborphan)
        [[ $MODE == report ]] || MODE=apply
        cmd_deborphan
        print_summary
        ;;
    keep)
        cmd_keep "$@"
        ;;
    *)
        error "Unknown command: $COMMAND"
        usage >&2
        exit 2
        ;;
esac
